# ─── PaperApe Configuration ─────────────────────────────

# Mode (set to "true" for mock/development mode — no Firebase required)
MOCK_MODE=true

# ─── Firebase (only required when MOCK_MODE=false) ──────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Privy Auth ─────────────────────────────────────────
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# ─── Birdeye (trending tokens, batch prices, search) ────
BIRDEYE_API_KEY=your-birdeye-api-key

# ─── MEVX (real-time price WebSocket) ───────────────────
MEVX_WS_URL=wss://ws.mevx.io/api/v1/ws

# ─── Helius (wallet tracking, holder data) ──────────────
HELIUS_API_KEY=your-helius-api-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key

# ─── Server ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,chrome-extension://your-extension-id

# ─── Frontend (apps/web/.env.local) ─────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
