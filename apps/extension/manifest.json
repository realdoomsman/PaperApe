{
  "manifest_version": 3,
  "name": "PaperApe - Simulated Trading",
  "version": "1.0.0",
  "description": "Paper trade Solana memecoins directly inside BullX, Padre, Photon, Axiom, and GMGN terminals.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bullx.io/*",
        "*://*.bullx.com/*",
        "*://*.padre.market/*",
        "*://*.padre.gg/*",
        "*://trade.padre.gg/*",
        "*://*.photon-sol.tinyastro.io/*",
        "*://*.photon.tinyastro.io/*",
        "*://*.axiom.trade/*",
        "*://*.gmgn.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://*.paperape.io/*",
        "https://*.paperape.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://localhost:3000/*",
    "*://*.bullx.io/*",
    "*://*.bullx.com/*",
    "*://*.padre.market/*",
    "*://*.padre.gg/*",
    "*://trade.padre.gg/*",
    "*://*.photon-sol.tinyastro.io/*",
    "*://*.photon.tinyastro.io/*",
    "*://*.axiom.trade/*",
    "*://*.gmgn.ai/*",
    "*://*.paperape.io/*",
    "*://*.paperape.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
